{
  "manifest_version": 3,
  "name": "Monoff",
  "version": "1.0",
  "description": "Turn web pages grayscale with a single click",
  "permissions": [
    "scripting",
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Grayscale Mode"
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["grayscale.css"],
      "run_at": "document_start"
    }
  ]
}
