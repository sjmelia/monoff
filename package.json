{
  "name": "monoff",
  "version": "1.0.2",
  "description": "Render pages in grayscale.",
  "type": "module",
  "scripts": {
    "icons": "node tools/generate-icons.js",
    "screenshots": "node tools/generate-screenshots.js",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:chrome": "wxt -b chrome",
    "compile": "wxt prepare && tsc --noEmit",
    "lint": "npm run compile",
    "build": "wxt build -b firefox && wxt build -b chrome",
    "zip": "wxt zip -b firefox && wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox",
    "zip:chrome": "wxt zip -b chrome"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sjmelia/monoff.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sjmelia/monoff/issues"
  },
  "homepage": "https://github.com/sjmelia/monoff#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "sharp": "^0.35.3",
    "typescript": "^7.0.2",
    "web-ext": "^10.4.0",
    "wxt": "^0.20.26"
  }
}
